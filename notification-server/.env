OPENSEARCH_PROTOCOL=http
OPENSEARCH_HOST=opensearch-node
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
PORT=4040
REFRESH_INTERVAL=1000
QUEUE_REFRESH_INTERVAL=1000
CORS_WHITELIST_ORIGINS=http://localhost:3001,http://localhost:3003,http://localhost:3004,http://localhost:8080,http://localhost:3009
RUUTER_URL=http://localhost:8086
PRIVATE_RUUTER_URL=http://localhost:8088
TERMINATION_TIMEOUT=10
AZURE_OPENAI_ENDPOINT=your-azure-endpoint
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-04-01-preview
AZURE_OPENAI_MODEL=gpt-3.5-turbo
AZURE_GRANT_TYPE=client_credentials
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SCOPE=https://ai.azure.com/.default
AZURE_AGENTIC_ENDPOINT=your-agentic-endpoint
AZURE_AGENTIC_PROJECT_NAME=your-project-name
AZURE_AGENTIC_API_VERSION=2025-11-15-preview
AZURE_AGENTIC_MAX_OUTPUT_TOKENS=4000
